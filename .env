# Supabase credentials are in .env.local (not committed to git)
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY must be set there.

# Brevo (Sendinblue) — used by Supabase Edge Function for email replies
# Set these via: npx supabase secrets set BREVO_API_KEY=xxx BREVO_FROM_EMAIL=xxx BREVO_FROM_NAME="Don Picaso Franchise"
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=
# BREVO_FROM_NAME=Don Picaso Franchise
